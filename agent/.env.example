# ─────────────────────────────────────────────────────────────
#  UniScout News Agent — environment
#  Copy to ".env" and fill in. NEVER commit .env. NEVER hardcode keys.
# ─────────────────────────────────────────────────────────────

# Language model — OPTIONAL. If set, it rephrases the scraped items into short,
# friendly language and classifies events vs articles. If omitted, the agent
# still works with built-in phrasing (no model needed).
# Works with an OpenAI key (sk-…) OR a Groq key (gsk_…, free + fast).
OPENAI_API_KEY=
# Model + base URL. Defaults: OpenAI → gpt-4o-mini. A gsk_ key is auto-detected as
# Groq (model llama-3.3-70b-versatile, base https://api.groq.com/openai/v1).
# OPENAI_MODEL=
# OPENAI_BASE_URL=

# Mailjet — REQUIRED to send. Public + Private keys from
# Mailjet → Account → REST API → API Key Management.
MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=

# The "from" address MUST be a validated sender in Mailjet
# (Mailjet → Senders & Domains → Add a sender → confirm via the email it sends).
EMAIL_FROM=youruniversityscout@gmail.com
EMAIL_TO=ivan.kharytonchuk10@gmail.com

# Optional: base URL your "Save to Deadlines" buttons point at (your app).
# APP_BASE=http://localhost:4242

# true = build + print the report but DON'T send the email (for testing).
DRY_RUN=false
