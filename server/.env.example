# ─────────────────────────────────────────────────────────────
#  UniScout — Stripe Elite subscription backend
#  Copy this file to ".env" and fill in real values.
#  NEVER commit the real .env file.  NEVER hardcode keys in code.
# ─────────────────────────────────────────────────────────────

# Stripe secret key (server-side only — keep secret!)
# Test mode keys start with sk_test_, live mode with sk_live_
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe publishable key (safe to expose to the browser)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook signing secret from `stripe listen` (whsec_...) or the Dashboard endpoint.
# Required so the server can verify that webhook calls really came from Stripe.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# OPTIONAL: a pre-created recurring Price ID (price_...).
# If left blank, the server auto-creates a "UniScout Elite" product +
# €15/year price on first boot and remembers it in the database.
STRIPE_PRICE_ID=

# Base URL the browser uses to reach this server. Used to build Stripe
# success/cancel/return URLs. Change to your real domain in production.
APP_URL=http://localhost:4242

# Port the server listens on.
PORT=4242

# OPTIONAL: path to the SQLite database file (defaults to ./uniscout.db)
DB_PATH=

# Accounts that are ALWAYS Elite without paying (admin/owner accounts).
# Comma-separated, matched case-insensitively against email OR username.
# Persisted to the database on first load, so it survives logout/login.
ELITE_ACCOUNTS=vanyochek

# OPTIONAL: token to authorise the POST /api/admin/grant-elite endpoint.
ADMIN_TOKEN=

# Email (for Google/Apple sign-in verification codes). Without these, codes are
# only printed to the server console (dev mode) and no real email is sent.
# For Gmail: create an "App Password" (Google account → Security → App passwords)
# and use it as SMTP_PASS with SMTP_USER = your gmail address.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=UniScout <your@gmail.com>

# ── UniScout Intelligence (Qdrant retrieval + OpenAI synthesis) ──
# Vector store for the real student/resident comments (semantic search).
QDRANT_URL=
QDRANT_API_KEY=
# QDRANT_COLLECTION=uniscout_comments

# OpenAI turns the retrieved real comments into one natural answer.
# Leave blank to run no-key extractive mode (still returns the real comments).
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
